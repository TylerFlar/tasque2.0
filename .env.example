TASQUE2_DATA_DIR=data
TASQUE2_TIMEZONE=America/Los_Angeles

# Local extension packages (personal domain modules); see extensions/README.md.
TASQUE2_EXTENSIONS_DIR=extensions

# Home location for the weather_now MCP tool (Open-Meteo, no API key needed).
TASQUE2_WEATHER_LATITUDE=32.7157
TASQUE2_WEATHER_LONGITUDE=-117.1611
TASQUE2_WEATHER_LOCATION_LABEL=San Diego, CA

# Android device automation (android_* MCP tools) over adb. Works with a
# physical phone (USB or wireless adb) or an emulator; serial is only needed
# when more than one device is attached (e.g. 127.0.0.1:5555 for an emulator,
# or <ip>:5555 for a wireless phone). Set the unlock PIN (digits only) to let
# sessions dismiss the lock screen; leave blank to require manual unlock.
TASQUE2_ANDROID_ADB_PATH=adb
TASQUE2_ANDROID_SERIAL=
TASQUE2_ANDROID_UNLOCK_PIN=

# Default model/provider adapter for jobs that use worker_kind=provider.default.
# Supported values: codex, claude.
TASQUE2_DEFAULT_PROVIDER=codex

# Model profiles for provider-backed work.
# Profiles: low, medium, high, ultra. The coordinator/orchestrator uses
# TASQUE2_ORCHESTRATOR_MODEL_PROFILE (default high); set the selected provider's
# model for that profile. Jobs can set runtime_contract.model_profile for the
# native/domain worker.
# Set TASQUE2_NATIVE_WORKER_MODEL_PROFILE as the default native-worker level for
# jobs that do not specify model_profile.
TASQUE2_ORCHESTRATOR_MODEL_PROFILE=high
TASQUE2_NATIVE_WORKER_MODEL_PROFILE=
TASQUE2_CODEX_MODEL_LOW=
TASQUE2_CODEX_MODEL_MEDIUM=
TASQUE2_CODEX_MODEL_HIGH=
TASQUE2_CODEX_MODEL_ULTRA=
TASQUE2_CLAUDE_MODEL_LOW=
TASQUE2_CLAUDE_MODEL_MEDIUM=
TASQUE2_CLAUDE_MODEL_HIGH=
TASQUE2_CLAUDE_MODEL_ULTRA=

# Discord bot.
TASQUE2_DISCORD_TOKEN=
TASQUE2_DISCORD_INTAKE_CHANNEL_ID=

# Split Discord channels. Ops/jobs/chains/DLQ are required; Tasque does not
# fall back from one route to another.
TASQUE2_DISCORD_OPS_CHANNEL_ID=
TASQUE2_DISCORD_JOBS_CHANNEL_ID=
TASQUE2_DISCORD_CHAINS_CHANNEL_ID=
TASQUE2_DISCORD_DLQ_CHANNEL_ID=
TASQUE2_DISCORD_OUTPUT_POLL_SECONDS=5

# Comma-separated Discord user ids allowed to queue/control local work.
# Leave blank only for a private single-user test server.
TASQUE2_DISCORD_ALLOWED_USER_IDS=
TASQUE2_DISCORD_MAX_ATTACHMENT_BYTES=26214400
